# ===========================================
# LLM Provider API Keys
# Configure at least ONE provider to enable AI features
# ===========================================

# OpenAI (https://platform.openai.com/api-keys)
OPENAI_API_KEY=

# Anthropic Claude (https://console.anthropic.com/)
ANTHROPIC_API_KEY=

# Google AI / Gemini (https://aistudio.google.com/apikey)
GOOGLE_AI_API_KEY=

# Zhipu AI / GLM (https://open.bigmodel.cn/)
ZHIPU_API_KEY=

# DeepSeek (https://platform.deepseek.com/)
DEEPSEEK_API_KEY=

# MiniMax (https://www.minimaxi.com/)
MINIMAX_API_KEY=

# ===========================================
# Active LLM Configuration
# Provider: openai | anthropic | google | zhipu | deepseek | minimax
# Model: see documentation for available models per provider
# ===========================================
LLM_PROVIDER=openai
LLM_MODEL=gpt-4o

# ===========================================
# Optional Configuration
# ===========================================

# Database (PostgreSQL - optional for local dev)
# DATABASE_URL=postgresql://user:password@host:5432/database

# Backend server port
API_PORT=3001

# Custom basemap URL
VITE_BASEMAP_URL=https://tile.openstreetmap.org/{z}/{x}/{y}.png